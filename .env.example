# Motherbrain MCP Environment Configuration
#
# ENDPOINTS:
#   Dashboard (humans):  http://your-host:3000
#   API/MCP (agents):    http://your-host:8000
#   MCP endpoint:        http://your-host:8000/mcp
#
# The MCP endpoint uses streamable HTTP (SSE). Agents connect directly to port 8000.
# The dashboard proxies API requests internally to avoid CORS issues.

# Database URL - uses asyncpg driver
# Use 'db' as hostname when running inside Docker, 'localhost' when running outside
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/motherbrain

# Redis URL
# Use 'redis' as hostname when running inside Docker, 'localhost' when running outside
REDIS_URL=redis://redis:6379

# Master API Key for admin-level access (change this in production!)
# Used by: API server, dashboard proxy, and agents
API_KEY=supersecret

# Fernet key for encrypting agent API credentials (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# If not set, a key will be generated on startup (not recommended for production)
# FERNET_KEY=your-fernet-key-here

# Agent configuration (for agent/agent.py)
# Use 'localhost' when running agent outside Docker
API_URL=http://localhost:8000
PLATFORM=python-agent
CAPABILITIES=["python", "shell", "docker"]

# CORS Origins - only needed if accessing the API directly from a browser
# (e.g., OpenAPI docs at /docs, or custom clients). Not needed for dashboard usage
# since the dashboard uses a proxy. Comma-separated list.
# CORS_ORIGINS=http://localhost:3000,http://your-hostname:3000

# Internal API URL for dashboard proxy - only needed for local dev without Docker
# Defaults to 'http://api:8000' which works inside Docker Compose
# API_INTERNAL_URL=http://localhost:8000
